# stlite bundle output — code + data are both build-time outputs.
# ``dashboard-static/files/``: python sources copied by build_stlite_bundle.py.
# ``dashboard-static/data/``:  witness parquets, either copied from
#                              local ``data/dashboard/`` (``--include-data``)
#                              or downloaded from the latest-data Release
#                              (``--fetch-from-release``).
# Only the hand-edited ``dashboard-static/index.html`` + README are checked in.
dashboard-static/files/
dashboard-static/data/
*.egg-info/
dist/
build/
.ruff_cache/
.pytest_cache/


# Local IDE/agent state
.claude/*
!.claude/skills/
.cursor/
.playwright-mcp/
.DS_Store
