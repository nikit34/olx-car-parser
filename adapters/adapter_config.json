{
    "adapter_path": "adapters",
    "batch_size": 1,
    "config": "config/mlx_lora.yaml",
    "data": "data/mlx_train",
    "fine_tune_type": "lora",
    "grad_accumulation_steps": 1,
    "grad_checkpoint": false,
    "iters": 600,
    "learning_rate": 0.0001,
    "lora_layers": 8,
    "lora_parameters": {
        "rank": 8,
        "alpha": 16,
        "dropout": 0.0,
        "scale": 2.0,
        "keys": [
            "self_attn.q_proj",
            "self_attn.v_proj"
        ]
    },
    "lr_schedule": {
        "name": "cosine_decay",
        "warmup": 50,
        "arguments": [
            0.0001,
            600
        ]
    },
    "mask_prompt": false,
    "max_seq_length": 1536,
    "model": "Qwen/Qwen2.5-3B-Instruct",
    "num_layers": 16,
    "optimizer": "adam",
    "optimizer_config": {
        "adam": {},
        "adamw": {},
        "muon": {},
        "sgd": {},
        "adafactor": {}
    },
    "project_name": null,
    "report_to": null,
    "resume_adapter_file": null,
    "save_every": 200,
    "seed": 42,
    "steps_per_eval": 100,
    "steps_per_report": 25,
    "test": false,
    "test_batches": 500,
    "train": true,
    "val_batches": 5
}